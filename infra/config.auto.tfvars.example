## Local, non-committed config for `infra/`
## Copy to `config.auto.tfvars` and edit.
##
## NOTE: `config.auto.tfvars` is automatically loaded by Terraform.
## Keep real credentials out of git.

# Proxmox
pm_api_url  = "https://proxmox.example.com:8006/api2/json"
pm_user     = "root@pam"
pm_password = "change-me"
pm_node     = "pve"

# Optional (defaults are fine for most cases)
# pm_tls_insecure = true
# pm_timeout = 3600
# vm_bridge       = "vmbr1"
# vm_storage      = "local-lvm"
# vm_data_storage = "nvme_pool"
# vm_worker_data_disk_gb = 500   # xd-w-* only; control planes have no data disk
# vm_control_plane_memory_mb = 4096   # xd-c-* (4 GiB)
# vm_worker_memory_mb        = 12288  # xd-w-* (12 GiB)

# Cluster identity / DNS
# cluster_name   = "xd-net"
# domain_suffix  = "k8s.net.ecksd.ee"
# cluster_endpoint = "https://k8s.net.ecksd.ee:6443"

# Talos pins (normally leave defaults from `infra/variables.tf`)
# talos_version  = "v1.13.0"
# talos_iso_url  = "https://factory.talos.dev/image/<schematic>/<version>/metal-amd64-secureboot.iso"
# talos_iso_name = "talos-<version>-metal-amd64-secureboot.iso"

# Network (Proxmox VLAN tags on vmbr*)
# vm_vlan_id = 4              # primary NIC — compute (192.168.4.0/24)
# worker_iot_vlan_id = 2      # second worker NIC — IoT w/ internet (192.168.2.0/24); null to disable
# IoT NIC is macvlan parent only (no host IP). Kubelet InternalIP stays on 192.168.4.0/24 (patches/kubelet-node-ip.yaml).
